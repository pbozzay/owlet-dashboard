OWLET_EMAIL=your-owlet-login@example.com
OWLET_PASSWORD=your-owlet-password
# Usually "world" for US/global accounts, "europe" for EU accounts.
OWLET_REGION=world
POLL_INTERVAL_SECONDS=5
DATABASE_PATH=data/owlet.sqlite3
HOST=127.0.0.1
PORT=8788
# Optional but strongly recommended before exposing the dashboard through a tunnel.
OWLET_BASIC_AUTH_USERNAME=parent
OWLET_BASIC_AUTH_PASSWORD=change-me-to-a-long-random-password
# Optional long random token for an unauthenticated read-only share URL.
# Anyone with /share/<token> can view the dashboard data exposed by the share routes.
OWLET_SHARE_TOKEN=change-me-to-a-long-random-token
